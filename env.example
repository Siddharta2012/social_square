# Social Square environment variables
# Copy this file to .env and fill in the values.

# Server
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5173

# Persistence
# DATABASE_URL is required for production readiness checks.
DATABASE_URL=postgresql://ssuser:sspassword@localhost:5432/socialsquare
REDIS_URL=redis://localhost:6379
REDIS_MOCK=false

# Auth
# Required outside tests.
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this
JWT_EXPIRES_IN=7d
ALLOW_PASSWORD_LOGIN=false
ALLOW_LEGACY_SOCKET_AUTH=false
# Protects /metrics and /api/admin/* when set.
ADMIN_TOKEN=change-this-admin-token

# Google OAuth (set all three or leave all blank)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# LiveKit voice (set all three or leave all blank)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# Error reporting (optional; no-op when blank)
ERROR_REPORT_DSN=
VITE_ERROR_REPORT_DSN=

# Client (Vite uses the VITE_ prefix)
VITE_API_URL=http://localhost:3000
VITE_SOCKET_URL=http://localhost:3000
VITE_LIVEKIT_URL=
