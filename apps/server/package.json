{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node ../../scripts/migrate.mjs",
    "import:redis-users": "node ../../scripts/import-redis-users.mjs",
