    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "ioredis-mock": "^8.13.1",
    "jsonwebtoken": "^9.0.3",
    "livekit-server-sdk": "^2.15.5",
    "pg": "^8.16.3",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.15.6",
    "tsx": "^4.16.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.1"
